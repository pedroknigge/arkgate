{
  "name": "ark-runtime-kernel",
  "version": "1.18.0",
  "description": "AI architecture gate for TypeScript repos, agents, and CI",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./eslint": {
      "types": "./dist/eslint/index.d.ts",
      "import": "./dist/eslint/index.js",
      "require": "./dist/eslint/index.cjs"
    },
    "./nestjs": {
      "types": "./dist/nestjs/index.d.ts",
      "import": "./dist/nestjs/index.js",
      "require": "./dist/nestjs/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "ark": "bin/ark.mjs",
    "ark-check": "bin/ark-check.mjs",
    "ark-mcp": "bin/ark-mcp.mjs"
  },
  "mcpName": "io.github.pedroknigge/ark",
  "files": [
    "bin",
    "dist",
    "docs/agent-guide.md",
    "docs/enthusiast",
    "docs/demos",
    "docs/ai-gates.md",
    "docs/ark-check-example.json",
    "docs/assets",
    "docs/brownfield-adoption.md",
    "docs/production-hardening.md",
    "templates",
    "server.json",
    "README.md",
    "CHANGELOG.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit",
    "security:audit": "npm audit --omit=dev --audit-level=high",
    "check:architecture": "node bin/ark-check.mjs --root . --config ark.config.json --strict-config",
    "eval:agent": "node eval/run.mjs",
    "eval:comparative": "node eval/comparative-run.mjs",
    "clean": "rm -rf dist",
    "release:npm": "node scripts/release-npm.mjs",
    "prepack": "npm run build"
  },
  "peerDependencies": {
    "@nestjs/common": ">=9"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": {
      "optional": true
    }
  },
  "overrides": {
    "vite": "6.4.3",
    "tsup": {
      "esbuild": "0.28.1"
    },
    "bundle-require": {
      "esbuild": "0.28.1"
    }
  },
  "devDependencies": {
    "@nestjs/common": "^11.1.27",
    "@types/node": "^20.14.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "tsup": "^8.1.0",
    "typescript": "^5.5.3",
    "vitest": "^3.2.6"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "architecture",
    "ddd",
    "event-driven",
    "hexagonal",
    "clean-architecture",
    "governance",
    "kernel",
    "policy",
    "nestjs",
    "ai-agents",
    "mcp",
    "lint",
    "architecture-fitness",
    "architecture-enforcement",
    "import-rules",
    "dependency-rules",
    "boundaries",
    "layered-architecture",
    "ai-code-gate"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pedroknigge/ark-runtime-kernel.git"
  },
  "publishConfig": {
    "access": "public"
  }
}
