{
  "name": "structrail",
  "version": "3.0.0",
  "description": "Structrail — architecture guardrails for AI TypeScript (write gate, CI gate, plan/loop)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "import": "./dist/runtime/index.js",
      "require": "./dist/runtime/index.cjs"
    },
    "./eslint": {
      "types": "./dist/eslint/index.d.ts",
      "import": "./dist/eslint/index.js",
      "require": "./dist/eslint/index.cjs"
    },
    "./nestjs": {
      "types": "./dist/nestjs/index.d.ts",
      "import": "./dist/nestjs/index.js",
      "require": "./dist/nestjs/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "structrail": "bin/structrail.mjs",
    "structrail-check": "bin/structrail-check.mjs",
    "structrail-mcp": "bin/structrail-mcp.mjs"
  },
  "mcpName": "io.github.pedroknigge/structrail",
  "files": [
    "bin",
    "bin/lib",
    "dist",
    "docs/agent-guide.md",
    "docs/enthusiast",
    "docs/demos",
    "docs/ai-gates.md",
    "docs/migrate-from-ark-runtime-kernel.md",
    "docs/typescript-support.md",
    "docs/structrail-check-example.json",
    "docs/assets",
    "docs/brownfield-adoption.md",
    "docs/package-surface.md",
    "docs/production-hardening.md",
    "docs/threat-model.md",
    "tests/fixtures/ts-consumer",
    "templates",
    "server.json",
    "README.md",
    "CHANGELOG.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "npm run build && vitest run --coverage --coverage.reporter=text-summary --coverage.reporter=json-summary",
    "test:mutation": "npm run build && stryker run",
    "test:confidence": "npm run test:coverage && npm run test:mutation",
    "typecheck": "tsc --noEmit",
    "security:audit": "npm audit --omit=dev --audit-level=high",
    "check:identity": "node scripts/check-legacy-identity.mjs",
    "check:architecture": "node bin/structrail-check.mjs --root . --config structrail.config.json --strict",
    "check:js": "node scripts/check-js-syntax.mjs",
    "generate:layer-match": "node scripts/generate-layer-match.mjs",
    "check:layer-match": "node scripts/generate-layer-match.mjs --check",
    "generate:cli-pure": "node scripts/generate-cli-pure.mjs",
    "check:cli-pure": "node scripts/generate-cli-pure.mjs --check",
    "check:gallery-starters": "node scripts/check-gallery-starters.mjs",
    "generate:gallery-starters": "node scripts/check-gallery-starters.mjs --write",
    "test:ts-compat": "node scripts/ts-compat-matrix.mjs 5.9.3 && node scripts/ts-compat-matrix.mjs 6.0.3 && node scripts/ts-compat-matrix.mjs 7.0.2",
    "eval:agent": "node eval/run.mjs",
    "eval:corpus": "node eval/validate-corpus.mjs",
    "eval:comparative": "node eval/comparative-run.mjs",
    "eval:loop-cost": "node eval/loop-cost-run.mjs",
    "bench:scale": "node scripts/ark-scale-bench.mjs",
    "check:module-budgets": "node scripts/check-module-budgets.mjs",
    "check:package-files": "node scripts/verify-package-files.mjs",
    "clean": "rm -rf dist",
    "release:npm": "node scripts/release-npm.mjs",
    "prepack": "npm run build"
  },
  "dependencies": {
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@nestjs/common": ">=9",
    "typescript": ">=5.0.0 <8"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": {
      "optional": true
    },
    "typescript": {
      "optional": true
    }
  },
  "overrides": {
    "qs": "6.15.3",
    "vite": "6.4.3",
    "tsup": {
      "esbuild": "0.28.1"
    },
    "bundle-require": {
      "esbuild": "0.28.1"
    }
  },
  "devDependencies": {
    "@nestjs/common": "^11.1.27",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "^20.14.0",
    "@vitest/coverage-v8": "^3.2.6",
    "pnpm": "10.34.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "tsup": "^8.1.0",
    "vitest": "^3.2.6",
    "yarn": "1.22.22"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "structrail",
    "architecture",
    "architecture-gate",
    "ai-agents",
    "mcp",
    "write-gate",
    "hexagonal",
    "clean-architecture",
    "layered-architecture",
    "import-rules",
    "dependency-rules",
    "boundaries",
    "co-pilot",
    "governance",
    "typescript",
    "eslint",
    "nestjs",
    "architecture-enforcement"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pedroknigge/arkgate.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "bugs": {
    "url": "https://github.com/pedroknigge/arkgate/issues"
  }
}
