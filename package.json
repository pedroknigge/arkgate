{
  "name": "ark-runtime-kernel",
  "version": "1.4.0",
  "description": "Architectural Runtime Kernel — governance for Hexagonal + Event-Driven + DDD systems",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./eslint": {
      "types": "./dist/eslint/index.d.ts",
      "import": "./dist/eslint/index.js",
      "require": "./dist/eslint/index.cjs"
    },
    "./nestjs": {
      "types": "./dist/nestjs/index.d.ts",
      "import": "./dist/nestjs/index.js",
      "require": "./dist/nestjs/index.cjs"
    }
  },
  "bin": {
    "ark": "bin/ark.mjs",
    "ark-check": "bin/ark-check.mjs",
    "ark-mcp": "bin/ark-mcp.mjs"
  },
  "mcpName": "io.github.pedroknigge/ark",
  "files": [
    "bin",
    "dist",
    "docs",
    "server.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit",
    "check:architecture": "node bin/ark-check.mjs --root . --config ark.config.json --strict-config",
    "clean": "rm -rf dist",
    "postinstall": "node bin/ark-postinstall.mjs",
    "release:npm": "node scripts/release-npm.mjs",
    "prepack": "npm run build"
  },
  "peerDependencies": {
    "@nestjs/common": ">=9"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nestjs/common": "^10.4.22",
    "@types/node": "^20.14.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "tsup": "^8.1.0",
    "typescript": "^5.5.3",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "architecture",
    "ddd",
    "event-driven",
    "hexagonal",
    "clean-architecture",
    "governance",
    "kernel",
    "policy",
    "nestjs",
    "ai-agents",
    "mcp",
    "lint",
    "architecture-fitness",
    "architecture-enforcement",
    "import-rules",
    "dependency-rules",
    "boundaries",
    "layered-architecture",
    "ai-code-gate"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pedroknigge/ark-runtime-kernel.git"
  }
}
