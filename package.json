{
  "name": "arkgate",
  "version": "2.5.0",
  "description": "ArkGate — architecture co-pilot for AI TypeScript (write gate, CI gate, plan/loop)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./eslint": {
      "types": "./dist/eslint/index.d.ts",
      "import": "./dist/eslint/index.js",
      "require": "./dist/eslint/index.cjs"
    },
    "./nestjs": {
      "types": "./dist/nestjs/index.d.ts",
      "import": "./dist/nestjs/index.js",
      "require": "./dist/nestjs/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "arkgate": "bin/ark.mjs",
    "arkgate-check": "bin/ark-check.mjs",
    "arkgate-mcp": "bin/ark-mcp.mjs",
    "ark": "bin/ark.mjs",
    "ark-check": "bin/ark-check.mjs",
    "ark-mcp": "bin/ark-mcp.mjs"
  },
  "mcpName": "io.github.pedroknigge/arkgate",
  "files": [
    "bin",
    "dist",
    "docs/agent-guide.md",
    "docs/enthusiast",
    "docs/demos",
    "docs/ai-gates.md",
    "docs/migrate-from-ark-runtime-kernel.md",
    "docs/typescript-support.md",
    "docs/ark-check-example.json",
    "docs/assets",
    "docs/brownfield-adoption.md",
    "docs/production-hardening.md",
    "tests/fixtures/ts-consumer",
    "templates",
    "server.json",
    "README.md",
    "CHANGELOG.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit",
    "security:audit": "npm audit --omit=dev --audit-level=high",
    "check:architecture": "node bin/ark-check.mjs --root . --config ark.config.json --strict-config",
    "test:ts-compat": "node scripts/ts-compat-matrix.mjs 5.9.3 && node scripts/ts-compat-matrix.mjs 6.0.3 && node scripts/ts-compat-matrix.mjs 7.0.2",
    "eval:agent": "node eval/run.mjs",
    "eval:comparative": "node eval/comparative-run.mjs",
    "clean": "rm -rf dist",
    "release:npm": "node scripts/release-npm.mjs",
    "prepack": "npm run build"
  },
  "dependencies": {
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@nestjs/common": ">=9",
    "typescript": ">=5.0.0 <8"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": {
      "optional": true
    },
    "typescript": {
      "optional": true
    }
  },
  "overrides": {
    "vite": "6.4.3",
    "tsup": {
      "esbuild": "0.28.1"
    },
    "bundle-require": {
      "esbuild": "0.28.1"
    }
  },
  "devDependencies": {
    "@nestjs/common": "^11.1.27",
    "@types/node": "^20.14.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "tsup": "^8.1.0",
    "vitest": "^3.2.6"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "arkgate",
    "architecture",
    "architecture-gate",
    "ai-agents",
    "mcp",
    "write-gate",
    "hexagonal",
    "clean-architecture",
    "layered-architecture",
    "import-rules",
    "dependency-rules",
    "boundaries",
    "co-pilot",
    "governance",
    "typescript",
    "eslint",
    "nestjs",
    "architecture-enforcement"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pedroknigge/arkgate.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "bugs": {
    "url": "https://github.com/pedroknigge/arkgate/issues"
  },
  "homepage": "https://github.com/pedroknigge/arkgate#readme"
}
