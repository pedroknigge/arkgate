{
  "include": ["src"],
  "layers": [
    { "name": "DomainModel", "patterns": ["src/domain/**"], "intentPrefixes": ["Domain."] },
    { "name": "ApplicationOrchestration", "patterns": ["src/app/**"], "intentPrefixes": ["Application."] }
  ],
  "rules": [
    { "from": "DomainModel", "to": "ApplicationOrchestration", "allowed": false }
  ]
}
