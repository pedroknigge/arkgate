{
  "$schema": "https://unpkg.com/arkgate@3/schemas/ark.config.schema.json",
  "schemaVersion": "1.0",
  "include": ["src"],
  "layers": [
    { "name": "DomainModel", "patterns": ["src/domain/**"] },
    { "name": "Kernel", "patterns": ["src/kernel/**"] }
  ],
  "rules": [
    {
      "from": "DomainModel",
      "to": "Kernel",
      "allowed": false,
      "message": "Domain code must not import Kernel."
    }
  ]
}
