{
  "$schema": "https://unpkg.com/arkgate@2/schemas/ark.config.schema.json",
  "schemaVersion": "1.0",
  "include": ["src"],
  "layers": [
    {
      "name": "DomainModel",
      "patterns": ["src/domain/**"],
      "intentPrefixes": ["Domain."],
      "forbiddenGlobals": ["fetch", "process", "Date.now", "Math.random"]
    },
    {
      "name": "Kernel",
      "patterns": ["src/kernel/**", "src/index.ts", "src/version.ts"],
      "intentPrefixes": ["Kernel."]
    },
    {
      "name": "Tooling",
      "patterns": ["src/eslint/**"]
    },
    {
      "name": "FrameworkAdapters",
      "patterns": ["src/nestjs/**"]
    }
  ],
  "rules": [
    { "from": "FrameworkAdapters", "to": "Tooling", "allowed": false },
    { "from": "FrameworkAdapters", "to": "DomainModel", "allowed": false },
    { "from": "DomainModel", "to": "FrameworkAdapters", "allowed": false },
    { "from": "Kernel", "to": "FrameworkAdapters", "allowed": false },
    { "from": "Tooling", "to": "FrameworkAdapters", "allowed": false },
    { "from": "DomainModel", "to": "Kernel", "allowed": false },
    { "from": "DomainModel", "to": "Tooling", "allowed": false },
    { "from": "Kernel", "to": "Tooling", "allowed": false },
    { "from": "Tooling", "to": "Kernel", "allowed": false },
    { "from": "Tooling", "to": "DomainModel", "allowed": false }
  ]
}
