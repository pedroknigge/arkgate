{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "rootDir": "./src",
    "types": ["node"],
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@domain/*": ["./src/domain/*"]
    }
  },
  "include": ["src/**/*.ts"]
}
