{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "timeout": 30,
            "command": "node bin/structrail-mcp.mjs --session-context --root \"${GROK_WORKSPACE_ROOT:-${CLAUDE_PROJECT_DIR:-.}}\" --config structrail.config.json"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|write|search_replace",
        "hooks": [
          {
            "type": "command",
            "timeout": 30,
            "command": "node bin/structrail-mcp.mjs --hook --hook-repair --root \"${GROK_WORKSPACE_ROOT:-${CLAUDE_PROJECT_DIR:-.}}\" --config structrail.config.json"
          }
        ]
      }
    ]
  }
}
