  },
  "dependencies": {},
  "peerDependencies": {},
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "architecture",
    "ddd",
    "event-driven",
    "hexagonal",
    "clean-architecture",
    "governance",
    "kernel",
    "policy"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pedroknigge/ark-runtime-kernel.git"
  }
