      "sliceFolders": [
        "contexts",
        "bounded-contexts"
      ],
      "message": "Bounded contexts must not import each other. Use shared kernel or integration events."
    },
    {
      "from": "PersistenceAdapters",
      "to": "PresentationAdapters",
      "allowed": false,
      "peerIsolation": true,
      "sliceFolders": [
        "contexts",
        "bounded-contexts"
      ],
      "message": "Bounded contexts must not import each other. Use shared kernel or integration events."
    },
    {
      "from": "PersistenceAdapters",
      "to": "PersistenceAdapters",
      "allowed": false,
      "peerIsolation": true,
      "sliceFolders": [
        "contexts",
        "bounded-contexts"
      ],
      "message": "Bounded contexts must not import each other. Use shared kernel or integration events."
    }
  ]
}
